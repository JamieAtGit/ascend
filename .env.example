# ASCEND cloud sync — copy this file to .env.local and fill in your values.
# Get both from your Supabase project: Settings → API.
# Without these the app runs fully local (no accounts, no sync) — that's fine.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Note: the anon key is safe to expose in frontend code — data access is
# protected by Row Level Security policies (see supabase/schema.sql),
# not by keeping this key secret.
